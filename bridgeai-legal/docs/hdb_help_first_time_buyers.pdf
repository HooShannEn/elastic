    function jsLogging() {

        var u = "https://services2.hdb.gov.sg/webapp/FI10AWCOMMON/FI10SAjaxHandlerNP";

        $.ajax({
            url: u,
            type: "POST",
            data: { title: document.title, url: location.href, esvcid: "", callback: "swallowLog" },
            dataType: "jsonp",
            jsonpCallback: "swallowLog",
            timeout: 2000,
            error: function () {/*user not login,swallow error*/ }
        });

        return false;
    }

